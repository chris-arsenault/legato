#!/bin/bash
set -euo pipefail

STATE_DIR="/Library/Application Support/Legato"
CERT_DIR="${STATE_DIR}/certs"
CONFIG_EXAMPLE="${STATE_DIR}/legatofs.toml.example"
CONFIG_PATH="${STATE_DIR}/legatofs.toml"
CERT_README="${CERT_DIR}/README.txt"

mkdir -p "${STATE_DIR}" "${CERT_DIR}" "${STATE_DIR}/catalog" "${STATE_DIR}/segments" "${STATE_DIR}/checkpoints"

if [ -f "${STATE_DIR}/certs-README.txt" ] && [ ! -f "${CERT_README}" ]; then
  mv "${STATE_DIR}/certs-README.txt" "${CERT_README}"
fi

if [ -f "${CONFIG_EXAMPLE}" ] && [ ! -f "${CONFIG_PATH}" ]; then
  cp "${CONFIG_EXAMPLE}" "${CONFIG_PATH}"
fi

chmod 755 /usr/local/bin/legatofs
chmod 755 /usr/local/bin/legato-register-client
chmod 755 /usr/local/bin/legato-setup-client
chmod 755 "${STATE_DIR}"
chmod 700 "${CERT_DIR}"

CLIENT_NAME="$(/usr/sbin/scutil --get LocalHostName 2>/dev/null || /bin/hostname)"
/usr/local/bin/legatofs install \
  --client-name "${CLIENT_NAME}" \
  --mount-point "/Volumes/Legato" \
  --state-dir "${STATE_DIR}" \
  --library-root "/" \
  --force

CONSOLE_USER="$(/usr/bin/stat -f %Su /dev/console)"
if [ -n "${CONSOLE_USER}" ] && [ "${CONSOLE_USER}" != "root" ] && [ "${CONSOLE_USER}" != "loginwindow" ]; then
  CONSOLE_UID="$(/usr/bin/id -u "${CONSOLE_USER}")"
  CONSOLE_HOME="$(/usr/bin/dscl . -read "/Users/${CONSOLE_USER}" NFSHomeDirectory | /usr/bin/awk '{print $2}')"
  /bin/launchctl asuser "${CONSOLE_UID}" /usr/bin/sudo -u "${CONSOLE_USER}" HOME="${CONSOLE_HOME}" /usr/local/bin/legatofs service install --force
  /bin/launchctl asuser "${CONSOLE_UID}" /usr/bin/sudo -u "${CONSOLE_USER}" HOME="${CONSOLE_HOME}" /usr/local/bin/legatofs service start
fi

exit 0
